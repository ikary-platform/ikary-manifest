{
  "name": "@ikary/try-api",
  "version": "0.3.0",
  "private": true,
  "description": "try.ikary.co API — thin NestJS shell wiring system-ai + cell-ai for the public demo.",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=.env.local src/main.ts",
    "build": "tsup",
    "start": "node dist/main.cjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ikary/cell-ai": "workspace:*",
    "@ikary/cell-contract": "workspace:*",
    "@ikary/system-ai": "workspace:*",
    "@nestjs/common": "^11.1.0",
    "@nestjs/core": "^11.1.0",
    "@nestjs/platform-express": "^11.1.0",
    "express": "^5.1.0",
    "openai": "^4.76.0",
    "partial-json": "^0.1.7",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "yaml": "^2.7.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^20.0.0",
    "tsup": "^8.0.2",
    "tsx": "^4.19.0",
    "typescript": "^5.5.3"
  }
}
