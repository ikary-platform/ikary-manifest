# try.ikary.co API — example env
PORT=4510
NODE_ENV=development

# Providers (comma-separated list picks order)
AI_PROVIDER_ORDER=openrouter
AI_OPENROUTER_API_KEYS=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxx

# Task → model fallback chain (semicolon-separated).
# The router tries each model in order; on provider error or invalid-manifest
# output it rotates to the next one and emits an attempt-fallback event so
# the SPA can show "rotated to <next>". Start with free models to prove the
# declarative-is-cheap narrative; only fall back to paid if they all misfire.
# MANIFEST_FIX and MANIFEST_UPDATE inherit from MANIFEST_GENERATE if unset.
AI_MODEL_MANIFEST_GENERATE=claude-haiku-4-5;claude-sonnet-4-6;nvidia/nemotron-3-super-120b-a12b:free;google/gemma-4-31b-it:free
AI_MODEL_MANIFEST_CLARIFY=openai/gpt-4.1-mini
AI_MODEL_CHAT_CONVERSE=anthropic/claude-haiku-4-5

# Budgets (env-tunable, no redeploy needed)
AI_BUDGET_PER_TURN_INPUT_TOKENS=2000
AI_BUDGET_PER_TURN_OUTPUT_TOKENS=2000
AI_BUDGET_PER_SESSION_TOKENS=40000
AI_BUDGET_PER_SESSION_MESSAGES=6
AI_BUDGET_GLOBAL_DAILY_USD=20

# Kill switch
FEATURE_AI_ENABLED=true

# MCP server (manifest validation + schema fetching). The executor calls these
# tools on every generation. Local-first; falls through to the public endpoint
# if local is unreachable; falls through to in-code Zod validation if both are.
# IKARY_MCP_URL=                                       # explicit override
# IKARY_MCP_LOCAL_URL=http://localhost:4502/mcp        # tried first
# IKARY_MCP_PUBLIC_URL=https://public.ikary.co/mcp     # fallback
# MANIFEST_VALIDATION_MAX_FIX_ATTEMPTS=2

# Rate-limit handling. Caching cuts ITPM by ~95% on repeated runs.
# Honoring Retry-After waits on the throttled model instead of rotating away.
# AI_PROMPT_CACHE_ENABLED=true
# AI_RATE_LIMIT_RETRY_AFTER_MAX_MS=30000
# AI_RATE_LIMIT_MAX_RETRIES_SAME_MODEL=2
# AI_RATE_LIMIT_BACKOFF_BASE_MS=500

# Optional override
# EXAMPLES_DIR=/path/to/manifests/examples
