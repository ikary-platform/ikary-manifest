# try.ikary.co API — example env
PORT=4510
NODE_ENV=development

# Providers (comma-separated list picks order)
AI_PROVIDER_ORDER=openrouter
AI_OPENROUTER_API_KEYS=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxx

# Task → model fallback chain (comma-separated).
# The router tries each model in order; on provider error or invalid-manifest
# output it falls through to the next one. Start with free models to prove the
# declarative-is-cheap narrative — only fall back to paid if they all misfire.
AI_MODEL_MANIFEST_GENERATE=openai/gpt-oss-120b:free,qwen/qwen3-next-80b-a3b-instruct:free,google/gemma-4-31b-it:free,anthropic/claude-sonnet-4-5
AI_MODEL_MANIFEST_CLARIFY=openai/gpt-4.1-mini
AI_MODEL_CHAT_CONVERSE=anthropic/claude-haiku-4-5

# Budgets (env-tunable, no redeploy needed)
AI_BUDGET_PER_TURN_INPUT_TOKENS=2000
AI_BUDGET_PER_TURN_OUTPUT_TOKENS=2000
AI_BUDGET_PER_SESSION_TOKENS=40000
AI_BUDGET_PER_SESSION_MESSAGES=6
AI_BUDGET_GLOBAL_DAILY_USD=20

# Kill switch
FEATURE_AI_ENABLED=true

# Optional override
# EXAMPLES_DIR=/path/to/manifests/examples
