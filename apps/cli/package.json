{
  "name": "@ikary-manifest/cli",
  "version": "0.0.1",
  "license": "MIT",
  "type": "module",
  "private": true,
  "bin": {
    "ikary": "./dist/cli.js"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ikary-manifest/contract": "workspace:*",
    "@ikary-manifest/loader": "workspace:*",
    "@ikary-manifest/engine": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.5.3",
    "tsup": "^8.0.2"
  }
}
