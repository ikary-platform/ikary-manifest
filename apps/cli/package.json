{
  "name": "@ikary/cli",
  "version": "0.3.0",
  "description": "IKARY Manifest CLI — generate, validate, compile, and preview Cell manifests",
  "license": "MIT",
  "type": "module",
  "bin": {
    "ikary": "./dist/cli.js"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ikary-platform/ikary-manifest.git",
    "directory": "apps/cli"
  },
  "homepage": "https://github.com/ikary-platform/ikary-manifest#readme",
  "bugs": "https://github.com/ikary-platform/ikary-manifest/issues",
  "keywords": [
    "ikary",
    "manifest",
    "cell",
    "cli",
    "scaffold",
    "validate"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "dev": "tsx src/bin/cli.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@ikary/system-migration-core": "workspace:*",
    "@ikary/cell-runtime-core": "workspace:*",
    "@ikary/cell-primitive-contract": "workspace:*",
    "@ikary/system-db-core": "workspace:*",
    "@ikary/system-localization": "workspace:*",
    "boxen": "^8.0.1",
    "chalk": "^5.4.1",
    "commander": "^13.0.0",
    "log-symbols": "^7.0.0",
    "ora": "^8.2.0",
    "prompts": "^2.4.2",
    "yaml": "^2.7.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@ikary/cell-contract": "workspace:*",
    "@ikary/cell-engine": "workspace:*",
    "@ikary/cell-loader": "workspace:*",
    "@types/prompts": "^2.4.9",
    "@vitest/coverage-v8": "^3.0.0",
    "tsup": "^8.0.2",
    "tsx": "^4.19.0",
    "typescript": "^5.5.3",
    "vitest": "^3.0.0"
  }
}
