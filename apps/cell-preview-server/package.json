{
  "name": "@ikary/cell-preview-server",
  "version": "0.3.0",
  "private": true,
  "description": "IKARY local preview server — Vite+React hot-reload renderer for local development",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:server": "tsup --config tsup.server.config.ts",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ikary/cell-branding": "workspace:*",
    "@ikary/cell-contract": "workspace:*",
    "@ikary/cell-data": "workspace:*",
    "@ikary/cell-engine": "workspace:*",
    "@ikary/cell-loader": "workspace:*",
    "@ikary/cell-presentation": "workspace:*",
    "@ikary/cell-primitives": "workspace:*",
    "@ikary/cell-primitive-contract": "workspace:*",
    "@ikary/cell-primitive-studio": "workspace:*",
    "@ikary/cell-renderer": "workspace:*",
    "@ikary/system-localization": "workspace:*",
    "lucide-react": "^1.8.0",
    "@tanstack/react-query": "^5.0.0",
    "express": "^5.1.0",
    "express-rate-limit": "^7.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^6.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "tsup": "^8.0.2",
    "typescript": "^5.5.3",
    "vite": "^6.0.0"
  }
}
