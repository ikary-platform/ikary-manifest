# try-demo (Vite SPA) - example env
#
# All variables are optional. Each one falls back to the production default
# baked into `src/config/links.ts` when unset. Override here (or in an
# untracked `.env.local`) to point the demo at a staging domain, a forked
# repo, or a local docs preview.
#
# Vite only exposes variables prefixed with `VITE_` to client code.

# VITE_IKARY_PRODUCT_URL=https://ikary.co
# VITE_IKARY_DOCS_URL=https://documentation.ikary.co
# VITE_IKARY_GITHUB_URL=https://github.com/ikary-platform/ikary-manifest
# VITE_IKARY_MCP_URL=https://mcp.ikary.co/v1
