{
  "name": "@ikary/system-log-core",
  "version": "0.3.0",
  "description": "Structured logging for IKARY services — Pino core, DB-backed sinks, cascading level settings, React terminal viewer.",
  "license": "MIT",
  "type": "module",
  "microPackageKind": "mixed",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./server": {
      "types": "./src/server/index.ts",
      "import": "./dist/server/index.js",
      "require": "./dist/server/index.cjs"
    },
    "./ui": {
      "types": "./src/ui/index.ts",
      "import": "./dist/ui/index.js",
      "require": "./dist/ui/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/core": "^10.0.0 || ^11.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "@nestjs/common": {
      "optional": true
    },
    "@nestjs/core": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "dependencies": {
    "@ikary/system-db-core": "workspace:*",
    "@tanstack/react-virtual": "^3.13.0",
    "lucide-react": "^0.469.0",
    "pino": "^9.0.0",
    "zod": "^3.0.0"
  },
  "optionalDependencies": {
    "pino-pretty": "^13.0.0"
  },
  "devDependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "tsup": "^8.0.2",
    "typescript": "^5.5.3",
    "vitest": "^3.0.0"
  },
  "files": [
    "dist",
    "src",
    "migrations",
    "README.md"
  ]
}
