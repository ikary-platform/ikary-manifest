{
  "name": "@ikary/cell-branding",
  "version": "0.3.0",
  "description": "Per-cell branding (accent color, fonts, theme mode) with NestJS server module and React provider/admin UI",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./server": {
      "types": "./src/server/index.ts",
      "import": "./dist/server/index.js",
      "require": "./dist/server/index.cjs"
    },
    "./ui": {
      "types": "./src/ui/index.ts",
      "import": "./dist/ui/index.js",
      "require": "./dist/ui/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src"
  },
  "dependencies": {
    "@ikary/system-db-core": "workspace:*",
    "zod": "^3.23.8"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/core": "^10.0.0 || ^11.0.0",
    "@tanstack/react-query": "^5.0.0",
    "kysely": "^0.27.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "reflect-metadata": "^0.2.0"
  },
  "peerDependenciesMeta": {
    "@nestjs/common": { "optional": true },
    "@nestjs/core": { "optional": true },
    "kysely": { "optional": true },
    "reflect-metadata": { "optional": true },
    "react": { "optional": true },
    "react-dom": { "optional": true },
    "@tanstack/react-query": { "optional": true }
  },
  "devDependencies": {
    "@nestjs/common": "^11.1.0",
    "@nestjs/core": "^11.1.0",
    "@tanstack/react-query": "^5.0.0",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jsdom": "^24.1.3",
    "kysely": "^0.27.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "reflect-metadata": "^0.2.2",
    "tsup": "^8.0.2",
    "typescript": "^5.5.3",
    "vitest": "^3.0.0"
  },
  "microPackageKind": "mixed",
  "files": [
    "dist",
    "src",
    "migrations",
    "README.md",
    "LICENSE"
  ]
}
