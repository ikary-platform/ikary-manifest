{
  "name": "@ikary/system-db-core",
  "version": "0.3.0",
  "description": "Shared Kysely-based database foundation for IKARY backend libraries and apps. Uses PostgreSQL via Kysely.",
  "license": "MIT",
  "type": "module",
  "microPackageKind": "server",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "kysely": "^0.27.0",
    "pg": "^8.13.0",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/pg": "^8.11.0",
    "@vitest/coverage-v8": "^3.0.0",
    "tsup": "^8.0.2",
    "typescript": "^5.5.3",
    "vitest": "^3.0.0"
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ]
}
