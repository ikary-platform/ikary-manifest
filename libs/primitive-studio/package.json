{
  "name": "@ikary/primitive-studio",
  "version": "0.1.1",
  "license": "MIT",
  "type": "module",
  "microPackageKind": "mixed-shared-ui",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./ui": {
      "types": "./src/ui/index.ts",
      "import": "./dist/ui/index.js",
      "require": "./dist/ui/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/ui/index.ts --format cjs,esm --dts --clean --external react --external @ikary/primitives",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src"
  },
  "dependencies": {
    "@ikary/primitive-contract": "workspace:*",
    "@ikary/primitives": "workspace:*",
    "zod": "^3.23.8"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "typescript": "^5.5.3",
    "tsup": "^8.0.2"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ]
}
