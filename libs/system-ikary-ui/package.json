{
  "name": "@ikary/system-ikary-ui",
  "version": "0.3.0",
  "description": "IKARY brand component library — logo, theme toggle, wave background, and brand tokens",
  "license": "MIT",
  "type": "module",
  "microPackageKind": "mixed-shared-ui",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./ui": {
      "types": "./src/ui/index.ts",
      "import": "./dist/ui/index.js",
      "require": "./dist/ui/index.cjs"
    },
    "./styles": {
      "default": "./dist/brand.css"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup && cp src/ui/styles/brand.css dist/brand.css",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "tsup": "^8.0.2",
    "typescript": "^5.5.3"
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  }
}
