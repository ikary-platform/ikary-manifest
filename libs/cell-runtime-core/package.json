{
  "name": "@ikary/cell-runtime-core",
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@ikary/contract": "workspace:*",
    "@ikary/engine": "workspace:*",
    "better-sqlite3": "^11.0.0",
    "kysely": "^0.27.0",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/pg": "^8.11.0",
    "tsup": "^8.0.2",
    "typescript": "^5.5.3",
    "vitest": "^3.0.0"
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ]
}
