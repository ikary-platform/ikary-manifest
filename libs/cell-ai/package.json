{
  "name": "@ikary/cell-ai",
  "version": "0.3.0",
  "description": "Cell-domain AI intelligence: manifest generation, schema-RAG, blueprint loading.",
  "license": "MIT",
  "type": "module",
  "microPackageKind": "mixed-shared-server",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./server": {
      "types": "./src/server/index.ts",
      "import": "./dist/server/index.js",
      "require": "./dist/server/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/server/index.ts --format cjs,esm --dts --clean",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@ikary/cell-contract": "workspace:*",
    "@ikary/cell-engine": "workspace:*",
    "@ikary/system-ai": "workspace:*",
    "@ikary/system-mcp": "workspace:*",
    "@ikary/system-prompt": "workspace:*",
    "@nestjs/common": "^11.1.0",
    "partial-json": "^0.1.7",
    "yaml": "^2.7.0",
    "zod": "^3.23.8"
  },
  "peerDependencies": {
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.2",
    "typescript": "^5.5.3",
    "vitest": "^3.0.0"
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ]
}
