{
  "name": "@ikary/primitives",
  "version": "0.2.0",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./registry": {
      "types": "./src/registry.ts",
      "import": "./dist/registry.js",
      "require": "./dist/registry.cjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/registry.ts --format cjs,esm --dts --clean --external react --external react-dom --external react-router-dom --external @ikary/contract --external @ikary/presentation --external lucide-react --external @tanstack/react-query --external @radix-ui/react-tabs --external @radix-ui/react-popover --external react-day-picker --external date-fns --external recharts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src"
  },
  "dependencies": {
    "@ikary/contract": "workspace:*",
    "@ikary/presentation": "workspace:*",
    "@ikary/primitive-contract": "workspace:*",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-tabs": "^1.1.13",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.8.0",
    "react-day-picker": "^9.14.0",
    "recharts": "^2.15.0",
    "tailwind-merge": "^3.4.0"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^6.30.1"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.0.0",
    "@types/react": "^19.0.0",
    "react-router-dom": "^6.30.1",
    "tsup": "^8.0.2",
    "typescript": "^5.5.3"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ]
}
