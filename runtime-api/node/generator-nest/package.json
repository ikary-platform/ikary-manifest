{
  "name": "@ikary/generator-nest",
  "version": "0.0.1",
  "license": "MIT",
  "type": "module",
  "private": true,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ikary/contract": "workspace:*",
    "@ikary/engine": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.5.3",
    "tsup": "^8.0.2"
  }
}
