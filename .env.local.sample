# Copy this file to .env.local and fill in your keys.
# .env.local is gitignored and loaded automatically by pnpm eval.

# --- Provider keys (at least one required for real-model eval runs) ---

AI_OPENROUTER_API_KEYS=sk-or-v1-your-key-here
# AI_ANTHROPIC_API_KEY=sk-ant-your-key-here
# AI_OPENAI_API_KEY=sk-your-key-here

# --- Model selection (semicolon-separated fallback chain) ---
# The router walks the chain top to bottom: if model A fails (HTTP error,
# rate-limit, invalid output) the runner rotates to B, then C, ... and emits
# attempt-fallback events so try-demo apps can show "rotated to <next>".
# Free models keep the declarative-is-cheap narrative. Paid Claude as last
# resort means the demo still ships a manifest if every free tier blew up.

AI_MODEL_MANIFEST_GENERATE=claude-haiku-4-5;claude-sonnet-4-6;nvidia/nemotron-3-super-120b-a12b:free;google/gemma-4-31b-it:free
# AI_MODEL_MANIFEST_FIX=...     (defaults to MANIFEST_GENERATE if unset)
# AI_MODEL_MANIFEST_UPDATE=...  (defaults to MANIFEST_GENERATE if unset)
# AI_MODEL_MANIFEST_CLARIFY=openai/gpt-4.1-mini
# AI_MODEL_CHAT_CONVERSE=anthropic/claude-haiku-4-5

# --- Provider routing ---

# AI_PROVIDER_ORDER=openrouter
# AI_PROVIDER_ORDER=anthropic,openrouter

# --- Budget caps ---

# AI_BUDGET_PER_TURN_INPUT_TOKENS=2000
# AI_BUDGET_PER_TURN_OUTPUT_TOKENS=6000
# AI_BUDGET_PER_SESSION_TOKENS=40000
# AI_BUDGET_GLOBAL_DAILY_USD=20

# --- MCP server (manifest validation + schema fetching) ---
# IKARY_MCP_URL=                                          # explicit override
# IKARY_MCP_LOCAL_URL=http://localhost:4502/mcp           # tried first
# IKARY_MCP_PUBLIC_URL=https://public.ikary.co/mcp        # fallback
# MANIFEST_VALIDATION_MAX_FIX_ATTEMPTS=2                  # cap for the post-validate fix loop

# --- Rate-limit handling ---
# AI_PROMPT_CACHE_ENABLED=true                            # Anthropic: wrap system prompt with cache_control
# AI_RATE_LIMIT_RETRY_AFTER_MAX_MS=30000                  # rotate to next model if Retry-After exceeds this
# AI_RATE_LIMIT_MAX_RETRIES_SAME_MODEL=2                  # how many times to retry the same model on 429
# AI_RATE_LIMIT_BACKOFF_BASE_MS=500                       # base for jittered exponential backoff in fix loop
# EVAL_RATE_LIMIT_DELAY_MS=0                              # eval inter-case sleep, useful on Tier 1 keys
