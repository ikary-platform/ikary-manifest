# Copy this file to .env.local and fill in your keys.
# .env.local is gitignored and loaded automatically by pnpm eval.

# --- Provider keys (at least one required for real-model eval runs) ---

AI_OPENROUTER_API_KEYS=sk-or-v1-your-key-here
# AI_ANTHROPIC_API_KEY=sk-ant-your-key-here
# AI_OPENAI_API_KEY=sk-your-key-here

# --- Model selection (OpenRouter model IDs, comma-separated fallback chain) ---

AI_MODEL_MANIFEST_GENERATE=google/gemma-4-31b-it:free
# AI_MODEL_MANIFEST_FIX=anthropic/claude-sonnet-4-5
# AI_MODEL_MANIFEST_UPDATE=anthropic/claude-sonnet-4-5
# AI_MODEL_MANIFEST_CLARIFY=openai/gpt-4.1-mini
# AI_MODEL_CHAT_CONVERSE=anthropic/claude-haiku-4-5

# --- Provider routing ---

# AI_PROVIDER_ORDER=openrouter
# AI_PROVIDER_ORDER=anthropic,openrouter

# --- Budget caps ---

# AI_BUDGET_PER_TURN_INPUT_TOKENS=2000
# AI_BUDGET_PER_TURN_OUTPUT_TOKENS=2000
# AI_BUDGET_PER_SESSION_TOKENS=40000
# AI_BUDGET_GLOBAL_DAILY_USD=20
