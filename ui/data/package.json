{
  "name": "@ikary/data",
  "version": "0.1.1",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean --external react --external react-dom --external react-router-dom --external @ikary/contract --external @ikary/presentation --external @ikary/primitives --external @tanstack/react-query",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src"
  },
  "dependencies": {
    "@ikary/contract": "workspace:*",
    "@ikary/presentation": "workspace:*",
    "@ikary/primitives": "workspace:*"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "@tanstack/react-query": "^5.0.0",
    "react-router-dom": "^6.30.1"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "typescript": "^5.5.3",
    "tsup": "^8.0.2",
    "@tanstack/react-query": "^5.0.0",
    "react-router-dom": "^6.30.1"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ]
}
