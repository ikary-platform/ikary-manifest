{
  "name": "@ikary-manifest/renderer",
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean --external react --external react-dom --external react-router-dom --external @ikary-manifest/contract --external @ikary-manifest/presentation --external @ikary-manifest/engine --external @ikary-manifest/primitives --external @tanstack/react-query --external react-hook-form --external @hookform/resolvers --external zod",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src"
  },
  "dependencies": {
    "@ikary-manifest/contract": "workspace:*",
    "@ikary-manifest/presentation": "workspace:*",
    "@ikary-manifest/engine": "workspace:*",
    "@ikary-manifest/primitives": "workspace:*",
    "react-hook-form": "^7.53.0",
    "@hookform/resolvers": "^3.9.0",
    "zod": "^3.23.8"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^6.0.0",
    "@tanstack/react-query": "^5.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.5.3",
    "tsup": "^8.0.2",
    "vitest": "^3.0.0"
  },
  "files": ["dist", "src", "README.md", "LICENSE"]
}
