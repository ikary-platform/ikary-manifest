[
  {
    "apiVersion": "ikary.co/v1alpha1",
    "kind": "Cell",
    "metadata": {
      "key": "crm",
      "name": "CRM Cell",
      "version": "1.0.0"
    },
    "spec": {
      "mount": {
        "mountPath": "/crm",
        "landingPage": "/crm/customers"
      },
      "entities": [
        {
          "key": "customer",
          "name": "Customer",
          "pluralName": "Customers",
          "fields": [
            {
              "key": "name",
              "type": "string",
              "name": "Name"
            }
          ]
        }
      ]
    }
  },
  {
    "apiVersion": "ikary.co/v1alpha1",
    "kind": "Cell",
    "metadata": {
      "key": "finance",
      "name": "Finance Cell",
      "version": "2.1.0",
      "description": "Finance operations"
    },
    "spec": {
      "mount": {
        "mountPath": "/finance",
        "landingPage": "/finance/dashboard"
      },
      "pages": [
        {
          "key": "dashboard",
          "type": "dashboard",
          "title": "Dashboard",
          "path": "/dashboard"
        }
      ]
    }
  },
  {
    "apiVersion": "ikary.co/v1alpha1",
    "kind": "Cell",
    "metadata": {
      "key": "support",
      "name": "Support Cell",
      "version": "1.3.2"
    },
    "spec": {
      "mount": {
        "title": "Support",
        "mountPath": "/support",
        "landingPage": "/support/tickets"
      },
      "navigation": {
        "items": [
          {
            "type": "page",
            "key": "ticketsNav",
            "pageKey": "tickets",
            "label": "Tickets"
          }
        ]
      },
      "pages": [
        {
          "key": "tickets",
          "type": "custom",
          "title": "Tickets",
          "path": "/tickets"
        }
      ]
    }
  },
  {
    "apiVersion": "ikary.co/v1alpha1",
    "kind": "Cell",
    "metadata": {
      "key": "ops",
      "name": "Ops Cell",
      "version": "0.9.0"
    },
    "spec": {
      "mount": {
        "mountPath": "/ops",
        "landingPage": "/ops/overview"
      },
      "roles": [
        {
          "key": "operator",
          "name": "Operator",
          "scopes": ["ops.view"]
        }
      ],
      "pages": [
        {
          "key": "overview",
          "type": "custom",
          "title": "Overview",
          "path": "/overview"
        }
      ]
    }
  },
  {
    "apiVersion": "ikary.co/v1alpha1",
    "kind": "Cell",
    "metadata": {
      "key": "projects",
      "name": "Projects Cell",
      "version": "3.0.0"
    },
    "spec": {
      "mount": {
        "mountPath": "/projects",
        "landingPage": "/projects/home"
      },
      "pages": [
        {
          "key": "home",
          "type": "dashboard",
          "title": "Projects Home",
          "path": "/home"
        }
      ]
    }
  }
]
