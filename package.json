{
  "name": "ikary-manifest",
  "version": "0.3.0",
  "private": true,
  "description": "Ikary Manifest — open-source declarative cell contracts, runtime engine, and React renderer",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently -n docs,api -c blue,green \"pnpm docs:dev\" \"pnpm --filter @ikary/mcp-server dev\"",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "vitest run --workspace vitest.workspace.ts",
    "test:e2e": "vitest run --project @ikary/mcp-server-e2e",
    "lint": "turbo run lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "coverage:contracts": "vitest run --coverage --root libs/cell-contract && vitest run --coverage --root libs/cell-loader && vitest run --coverage --root libs/cell-engine",
    "coverage:ui": "vitest run --coverage --root libs/cell-presentation && vitest run --coverage --root libs/cell-primitives && vitest run --coverage --root libs/cell-data && vitest run --coverage --root libs/cell-renderer",
    "coverage:system-db-core": "pnpm --filter @ikary/system-db-core test:coverage",
    "coverage:cell-runtime-core": "pnpm --filter @ikary/cell-runtime-core test:coverage",
    "coverage:system-migration-core": "pnpm --filter @ikary/system-migration-core test:coverage",
    "generate:schema": "tsx scripts/generate-json-schema.ts",
    "playground:build": "turbo run build --filter @ikary/cell-playground",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish",
    "docs:dev": "vitepress dev apps/docs",
    "docs:build": "pnpm playground:build && vitepress build apps/docs",
    "docs:preview": "vitepress preview apps/docs",
    "docs:check:freshness": "node scripts/check-docs-freshness.mjs",
    "docs:check:commands": "pnpm --filter @ikary/cli build && node scripts/check-docs-command-smoke.mjs",
    "docs:check": "pnpm docs:build && pnpm docs:check:freshness && pnpm docs:check:commands",
    "capture-cli-output": "tsx scripts/capture-cli-output.ts",
    "check:node-version": "node scripts/check-node-version.mjs",
    "evals:build-deps": "pnpm --filter @ikary/cell-contract build && pnpm --filter @ikary/cell-engine build && pnpm --filter @ikary/system-ai build && pnpm --filter @ikary/system-prompt build && pnpm --filter @ikary/cell-ai build",
    "evals:run": "pnpm evals:build-deps && tsx --env-file-if-exists=.env.local evals/scripts/run.ts",
    "evals:report": "tsx evals/scripts/report.ts",
    "evals:test": "vitest run --workspace vitest.workspace.ts --project @ikary/evals",
    "eval": "pnpm evals:run"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@nestjs/common": "^11.1.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitest/coverage-v8": "^3.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^10.2.0",
    "eslint-plugin-react-hooks": "^7.1.0",
    "handlebars": "^4.7.8",
    "jsdom": "^24.1.3",
    "partial-json": "^0.1.7",
    "prettier": "^3.3.0",
    "reflect-metadata": "^0.2.2",
    "tsup": "^8.0.2",
    "tsx": "^4.19.0",
    "turbo": "^2.8.0",
    "typescript": "^5.5.3",
    "vitepress": "^1.6.0",
    "vitest": "^3.0.0",
    "yaml": "^2.7.0",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.24.0"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@9.15.9"
}
