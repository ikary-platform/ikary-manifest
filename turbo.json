{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**",
        "tsconfig*.json",
        "tsup.config.*",
        "package.json"
      ],
      "outputs": ["dist/**"]
    },
    "build:standalone": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**",
        "vite.standalone.config.*",
        "tsconfig*.json",
        "package.json"
      ],
      "outputs": ["dist/standalone/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "tsconfig*.json", "package.json"],
      "outputs": []
    },
    "lint": {
      "inputs": ["src/**"],
      "outputs": []
    }
  }
}
