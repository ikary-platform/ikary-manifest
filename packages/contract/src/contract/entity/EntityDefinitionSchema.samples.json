        "key": "title",
        "type": "string",
        "name": "Title"
      },
      {
        "key": "budget",
        "type": "number",
        "name": "Budget",
        "display": {
          "type": "currency",
          "currency": "USD",
          "precision": 0
        }
      }
    ],
    "relations": [
      {
        "key": "owner",
        "relation": "belongs_to",
        "entity": "user",
        "required": true
      }
    ],
    "capabilities": [
