        "workflow": "archiveProject",
        "scope": "entity"
      }
    ],
    "policies": {
      "view": {
        "scope": "workspace"
      },
      "update": {
        "scope": "role",
        "condition": "role == 'manager'"
      }
    },
    "fieldPolicies": {
      "budget": {
        "view": {
          "scope": "role",
          "condition": "role == 'finance'"
        },
        "update": {
          "scope": "role",
          "condition": "role == 'finance'"
        }
      }
    }
  },
  {
    "key": "order",
