  {
    "key": "invoice",
    "name": "Invoice",
    "pluralName": "Invoices",
    "fields": [
      {
        "key": "number",
        "type": "string",
        "name": "Number"
      },
      {
        "key": "status",
        "type": "enum",
        "name": "Status",
        "enumValues": ["draft", "sent", "paid"]
      }
    ],
    "lifecycle": {
      "field": "status",
      "initial": "draft",
      "states": ["draft", "sent", "paid"],
      "transitions": [
        {
          "key": "send",
          "from": "draft",
          "to": "sent"
        },
        {
          "key": "markPaid",
          "from": "sent",
          "to": "paid"
        }
      ]
    },
    "events": {
      "names": {
        "created": "invoice.created",
        "updated": "invoice.updated"
      }
    }
  },
  {
    "key": "ticket",
    "name": "Ticket",
    "pluralName": "Tickets",
    "fields": [
      {
        "key": "subject",
        "type": "string",
        "name": "Subject"
      },
      {
        "key": "priority",
        "type": "enum",
        "name": "Priority",
        "enumValues": ["low", "medium", "high"],
        "display": {
          "type": "badge",
          "badgeToneMap": {
            "low": "info",
            "medium": "warning",
            "high": "danger"
          }
        }
      }
    ],
    "computed": [
      {
        "key": "isHighPriority",
        "name": "Is High Priority",
        "type": "boolean",
        "formulaType": "conditional",
        "condition": "priority == 'high'",
        "then": "true",
        "else": "false"
      }
    ],
    "validation": {
      "entityRules": [
        {
          "ruleId": "ticket_subject_required",
          "type": "entity_invariant",
          "paths": ["subject"],
          "messageKey": "validation.ticket.subject.required",
          "clientSafe": true,
          "blocking": true,
          "severity": "error"
        }
      ]
    }
  },
  {
    "key": "project",
    "name": "Project",
    "pluralName": "Projects",
    "fields": [
