{
  "apiVersion": "ikary.io/v1alpha1",
  "kind": "Cell",
  "metadata": {
    "key": "crm",
    "name": "CRM Cell",
    "version": "1.0.0"
  },
  "spec": {
    "mount": {
      "mountPath": "/crm",
      "landingPage": "customer-list"
    },
    "roles": [
      {
        "key": "admin",
        "name": "Admin",
        "scopes": ["crm.admin"]
      },
      {
        "key": "sales",
        "name": "Sales",
        "scopes": ["crm.customer.view"]
      }
    ],
    "entities": [
      {
        "key": "customer",
        "name": "Customer",
        "pluralName": "Customers",
        "fields": [
          {
            "key": "name",
            "type": "string",
            "name": "Name"
          },
          {
            "key": "email",
            "type": "string",
            "name": "Email"
          },
          {
            "key": "status",
            "type": "enum",
            "name": "Status",
            "enumValues": ["lead", "active", "inactive"]
          }
        ],
        "relations": [
          {
            "key": "invoices",
            "relation": "has_many",
            "entity": "invoice",
            "foreignKey": "customer_id"
          }
        ],
        "computed": [
          {
            "key": "invoiceCount",
            "name": "Invoice Count",
            "type": "number",
            "formulaType": "aggregation",
            "relation": "invoices",
            "operation": "count"
          }
        ],
        "lifecycle": {
          "field": "status",
          "initial": "lead",
          "states": ["lead", "active", "inactive"],
          "transitions": [
            {
              "key": "activate",
              "from": "lead",
              "to": "active"
            },
            {
              "key": "deactivate",
              "from": "active",
              "to": "inactive"
            }
          ]
        },
        "capabilities": [
          {
            "key": "activate",
            "type": "transition",
            "transition": "activate"
          }
        ]
      },
      {
        "key": "invoice",
        "name": "Invoice",
        "pluralName": "Invoices",
        "fields": [
          {
            "key": "number",
            "type": "string",
            "name": "Number"
          },
          {
            "key": "customer_id",
            "type": "string",
            "name": "Customer Id"
          },
          {
            "key": "amount",
            "type": "number",
            "name": "Amount"
          },
          {
            "key": "status",
            "type": "enum",
            "name": "Status",
            "enumValues": ["draft", "sent", "paid"]
          }
        ],
        "relations": [
          {
            "key": "customer_id",
            "relation": "belongs_to",
            "entity": "customer"
          }
        ]
      }
    ],
    "pages": [
      {
        "key": "dashboard",
        "type": "dashboard",
        "title": "Dashboard",
        "path": "/dashboard"
      },
      {
        "key": "customer-list",
        "type": "entity-list",
        "title": "Customers",
        "path": "/customers",
        "entity": "customer"
      },
      {
        "key": "customer-detail",
        "type": "entity-detail",
        "title": "Customer Detail",
        "path": "/customers/:id",
        "entity": "customer"
      }
    ],
    "navigation": {
      "items": [
        {
          "type": "page",
          "key": "dashboard",
          "pageKey": "dashboard"
        },
        {
          "type": "group",
          "key": "customers",
          "label": "Customers",
          "children": [
            {
              "type": "page",
              "key": "customer-list",
              "pageKey": "customer-list"
            }
          ]
        }
      ]
    }
  }
}
